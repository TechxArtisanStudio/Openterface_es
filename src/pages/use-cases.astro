---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { legacyPath } from '../config/site';
---

<BaseLayout
  title="Casos de Uso"
  description="Casos de uso del mundo real para los productos KVM-over-USB de Openterface."
  canonicalPath="/use-cases/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">Casos de Uso</h1>
      <p class="mt-4 text-lg text-muted">
        Las herramientas de Openterface destacan cuando necesitas controlar una computadora sin monitor o de difícil acceso sin un monitor y teclado dedicados.
      </p>
      <ul class="mt-8 space-y-4">
        {
          [
            'Recorridos por centros de datos y colocación',
            'Administración de homelabs y NAS',
            'Puesta en marcha de dispositivos embebidos y SBC',
            'Mantenimiento de quioscos y señalización digital',
            'TI de campo y consultoría',
          ].map((item) => (
            <li class="card">{item}</li>
          ))
        }
      </ul>
      <a href={legacyPath('/use-cases/')} class="btn btn-secondary mt-8" target="_blank" rel="noopener">
        Ver galería completa de casos de uso →
      </a>
    </div>
  </section>
</BaseLayout>
