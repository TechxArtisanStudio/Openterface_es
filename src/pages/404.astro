---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página no encontrada" description="La página que solicitaste no pudo ser encontrada." canonicalPath="/404">
  <section class="flex min-h-[50vh] flex-col items-center justify-center px-4 py-16 text-center">
    <h1 class="text-6xl font-bold text-primary-dark">404</h1>
    <p class="mt-4 text-xl text-muted">Página no encontrada</p>
    <a href="/" class="btn btn-primary mt-8">Volver al inicio</a>
  </section>
</BaseLayout>
