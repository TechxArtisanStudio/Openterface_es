---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocLinkBanner from '../../components/DocLinkBanner.astro';
import { legacyPath } from '../../config/site';
---

<BaseLayout
  title="Acerca de Openterface"
  description="Conoce Openterface: soluciones KVM-over-USB de código abierto creadas por TechxArtisan."
  ogImageAlt="Soluciones KVM-over-USB de código abierto de Openterface por TechxArtisan"
  canonicalPath="/about/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">Acerca de Openterface</h1>
      <p class="mt-6 text-lg leading-relaxed text-muted">
        Openterface crea herramientas KVM-over-USB de código abierto y ultracompactas para profesionales de TI, desarrolladores y makers.
        Desde el Mini-KVM financiado colectivamente hasta el KVM-GO de tamaño llavero y la serie programable KeyMod, nuestra misión es
        simplificar el control de computadoras sin monitor sin equipos voluminosos ni redes complejas.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={legacyPath('/about/about-us/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Acerca de nosotros completo →
        </a>
        <a href={legacyPath('/about/compliance/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Cumplimiento →
        </a>
        <a href={legacyPath('/about/community/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Comunidad →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
