---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { legacyPath } from '../config/site';
---

<BaseLayout
  title="Videos"
  description="Demos de productos, tutoriales y reseñas de Openterface en YouTube."
  canonicalPath="/videos/"
>
  <DocLinkBanner message="La cuadrícula completa de videos de YouTube filtrable está en el sitio antiguo hasta que portemos el pipeline de videos." />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-4xl font-bold">Videos</h1>
      <p class="mt-4 text-lg text-muted">
        Mira demos de productos, guías de configuración y reseñas de la comunidad para los productos Openterface KVM y KeyMod.
      </p>
      <a href={legacyPath('/videos/')} class="btn btn-primary mt-8" target="_blank" rel="noopener">
        Explorar todos los videos →
      </a>
    </div>
  </section>
</BaseLayout>
